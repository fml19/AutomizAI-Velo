# Copie este arquivo para .env e preencha apenas no ambiente local.
# No deploy, cadastre os mesmos nomes no painel da hospedagem.
VITE_SUPABASE_PROJECT_ID="seu_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="sua_chave_publica_do_supabase"
VITE_SUPABASE_URL="https://seu_project_id.supabase.co"

# Usada somente por testes e ferramentas no servidor. Nunca use no frontend.
DATABASE_URL="postgresql://usuario:senha@host:porta/banco"

# Opcional para os testes end-to-end.
BASE_URL="http://localhost:5173/"
